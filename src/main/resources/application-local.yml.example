# Local development profile template.
# Copy to application-local.yml (gitignored) and adjust for your machine.
# Run: SPRING_PROFILES_ACTIVE=local ./gradlew bootRun
#  or: -Dspring.profiles.active=local (IntelliJ VM options)
#
# Merges with application.yml; secrets come from env vars (DATABASE_URL, JWT_SECRET, ...).

spring:
  application:
    name: glucose-monitor-be
  datasource:
    url: ${DATABASE_URL:jdbc:postgresql://localhost:5432/glucose_monitor}
    username: ${DB_USERNAME:glucose_monitor_user}
    password: ${DB_PASSWORD:}          # set to your local Postgres password
    driver-class-name: org.postgresql.Driver
    hikari:
      maximum-pool-size: 10
  jpa:
    show-sql: true
    properties:
      hibernate:
        format_sql: true

security:
  jwt:
    # Generate a strong value: openssl rand -base64 64
    secret: ${JWT_SECRET:dev-only-insecure-jwt-secret-CHANGE-ME-do-not-use-in-production-0123456789}

server:
  error:
    include-stacktrace: always

logging:
  level:
    root: INFO
    che.glucosemonitorbe: DEBUG
    org.springframework.web.servlet.DispatcherServlet: DEBUG
    org.springframework.security: INFO

management:
  endpoints:
    web:
      exposure:
        include: health,info,loggers

app:
  ai:
    ollama:
      # Local Ollama; override with OLLAMA_URL for cloud
      url: ${OLLAMA_URL:http://localhost:11434/api/generate}
